<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo / Header -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_ecoguardian_logo"
            android:contentDescription="@string/app_name"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EcoGuardian Alert"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Estado de red -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_status_card"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_network"
                app:tint="#757575"/>

            <TextView
                android:id="@+id/txt_network_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Red mesh: buscando"
                android:textColor="#757575"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/txt_peer_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 contactos"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- Botones de alerta -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_alert"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Reportar amenaza"
            android:textSize="16sp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_sos"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="🆘 SOS Emergencia"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            android:layout_marginBottom="32dp"
            android:elevation="4dp"/>

        <!-- Indicador de progreso -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Información de seguridad -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔐 Tus alertas viajan cifradas por red mesh. No requieren internet."
            android:textSize="12sp"
            android:textColor="#616161"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:background="@drawable/bg_info_card"/>

        <!-- Footer con versión -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.1.0 • Toque triple en el logo para modo pánico"
            android:textSize="10sp"
            android:textColor="#BDBDBD"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
